# ====================================================================
# Cultura Unificada — variáveis de ambiente
# Copie este arquivo para ".env.local" e preencha com seus valores.
# Nunca coloque valores reais neste arquivo (.env.example) nem no git.
# ====================================================================

# Supabase — encontre em Project Settings > API no painel do Supabase
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-publica-aqui

# Google Maps — crie em https://console.cloud.google.com/google/maps-apis
# Ative a API "Maps JavaScript API" para o projeto e restrinja a chave ao
# seu domínio de produção (e a localhost para testes).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=sua-chave-do-google-maps-aqui
